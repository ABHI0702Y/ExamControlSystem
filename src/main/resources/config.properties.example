# ── Database ──────────────────────────────────────────────
db.url=jdbc:mysql://localhost:3306/exam_control_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
db.username=root
db.password=YOUR_MYSQL_PASSWORD

# ── HikariCP Connection Pool ──────────────────────────────
db.pool.maximumPoolSize=10
db.pool.minimumIdle=2
db.pool.connectionTimeout=30000
db.pool.idleTimeout=600000
db.pool.maxLifetime=1800000

# ── Application ───────────────────────────────────────────
app.name=Exam Control System
app.version=1.0.0
